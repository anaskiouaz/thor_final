# Server Configuration
PORT=3000

# Blockchain Configuration (Helius)
HELIUS_API_KEY=your_helius_api_key
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_TRANSACTIONS_URL=https://api-mainnet.helius-rpc.com/v0/transactions/?api-key=YOUR_KEY

# Blockchain Configuration (Helius Backup)
HELIUS_API_KEY1=
RPC_URL1=
WSS_URL1=
HELIUS_TRANSACTIONS_URL1=

# Solana Wallet (base58 encoded private key)
SOLANA_PRIVATE_KEY=your_base58_private_key_here
DEFAULT_BUY_AMOUNT=0.1

# Trading Configuration (Thor v2)
BUY_AMOUNT_EUR=8
MAX_PRIORITY_FEE_EUR=1
SLIPPAGE_BPS=8000
TP_PERCENT=100
SL_PERCENT=-70
ENTRY_PRICE_DELAY_SEC=5
AUTO_BUY_ENABLED=true
DRY_RUN=true

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
SOLSCAN_API_KEY=your_solscan_api_key

# Logging (Thor v2)
LOG_LEVEL=info
LOG_DIR=backend/logs
LOG_TO_FILE=true
LOG_MAX_SIZE_MB=20
LOG_MAX_FILES=14d
