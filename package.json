{
  "name": "thor",
  "version": "1.0.0",
  "description": "Wallet Token Tracker - Real-time contract deployment monitor",
  "scripts": {
    "real": "cd backend && npm run start:real",
    "sim": "cd backend && npm run start:sim",
    "ui": "cd frontend && npm run dev",
    "start:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && npm run dev",
    "test": "cd backend && npm run test",
    "dev": "concurrently \"npm run sim\" \"npm run ui\"",
    "setup": "node setup.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4"
  }
}
